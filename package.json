{
	"name": "pi-mixlayer",
	"version": "0.2.0",
	"description": "Mixlayer provider extension for pi.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi-provider",
		"mixlayer"
	],
	"files": [
		"dist",
		"README.md",
		"package.json"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc",
		"check": "tsc --noEmit",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.78.1",
		"typescript": "5.9.3"
	}
}